# AgentOps Mobile Command Center
# Copy to .env and fill only what you need for local demo or deployment.

APP_NAME=AgentOps Mobile Command Center
APP_ENV=demo
APP_DB_PATH=/data/agentops.sqlite3
APP_PUBLIC_URL=http://localhost:8000

# Optional demo integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_POLL_INTERVAL_SECONDS=3
GITHUB_TOKEN=
GITHUB_REPO=
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=30
AMD_API_KEY=
AMD_BASE_URL=https://api.amd.com/v1
AMD_TIMEOUT_SECONDS=30
AMD_MODEL=amd/mi300x-llama-3.1-70b
DEMO_PR_URL=https://github.com/example/repo/pull/42
